#!/usr/bin/env bash
# Configures Nginx to add a custom X-Served-By header with the server's hostname

# Install nginx if not already installed
sudo apt-get update
sudo apt-get install -y nginx

# Create a simple index page if it doesn't exist
if [ ! -f /var/www/html/index.html ]; then
    echo "Hello World!" | sudo tee /var/www/html/index.html
fi

# Add the custom header inside the server block, in the default site config
sudo sed -i '/server_name _;/a \\tadd_header X-Served-By $hostname;' /etc/nginx/sites-available/default

# Make sure nginx starts on boot and restart it now
sudo service nginx restart
